{
    "name": "velocityphp/framework",
    "description": "Ultra-fast, production-ready PHP framework with MVC architecture, SPA-like AJAX navigation, built-in caching, rate limiting, and a complete REST API layer.",
    "type": "project",
    "keywords": [
        "php",
        "framework",
        "velocityphp",
        "mvc",
        "fast",
        "performance",
        "rest-api",
        "caching",
        "middleware",
        "shared-hosting"
    ],
    "homepage": "https://github.com/prasangapokharel/VelocityPHP",
    "license": "MIT",
    "version": "1.1.0",
    "authors": [
        {
            "name": "Prasanga Pokharel",
            "email": "prasanga@prasangapokharel.com.np",
            "homepage": "https://www.prasangapokharel.com.np",
            "role": "Lead Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/prasangapokharel/VelocityPHP/issues",
        "source": "https://github.com/prasangapokharel/VelocityPHP"
    },
    "require": {
        "php": ">=7.4",
        "ext-pdo": "*",
        "ext-json": "*",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5"
    },
    "suggest": {
        "ext-opcache": "For optimal performance",
        "ext-apcu": "For enhanced in-memory caching"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "classmap-authoritative": false,
        "preferred-install": "dist",
        "sort-packages": true,
        "platform": {
            "php": "7.4"
        }
    },
    "scripts": {
        "start": "php start.php",
        "serve": "php -S localhost:8000 -t public",
        "test": "phpunit --testdox",
        "post-install-cmd": [
            "@php -r \"!file_exists('.env.velocity') && copy('.env.velocity.example', '.env.velocity');\""
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
