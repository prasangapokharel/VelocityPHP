# VelocityPHP Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# SHARED HOSTING / ZIP DEPLOY
#   1. Copy this file to  .env.velocity  (same directory, no extension change)
#   2. Fill in the values below with your real credentials
#   3. Never commit .env.velocity — it is in .gitignore by design
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="My VelocityPHP App"
APP_ENV=production
APP_DEBUG=false
# Set to your actual domain, no trailing slash (used for asset URLs, redirects)
APP_URL=https://yourdomain.com
# Generate with: php -r "echo bin2hex(random_bytes(32));"
APP_KEY=

# ── Database ──────────────────────────────────────────────────────────────────
# cPanel MySQL: host is usually 'localhost', database/user are prefixed with
# your cPanel username (e.g. myuser_dbname, myuser_dbuser)
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASS=your_database_password

# PostgreSQL example:
# DB_CONNECTION=pgsql
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=your_db
# DB_USER=your_user
# DB_PASS=your_password

# SQLite example (no server required — good for simple shared hosting):
# DB_CONNECTION=sqlite
# (database file will be created at storage/database.sqlite automatically)

# ── Cache ─────────────────────────────────────────────────────────────────────
CACHE_ENABLED=true
# Path to the SQLite cache file — relative to the project root.
# The directory must be writable by the web server.
CACHE_LOCATION=src/velocache/velocity.db

# ── Session ───────────────────────────────────────────────────────────────────
# Lifetime in minutes
SESSION_LIFETIME=120
# Set to true if your site runs on HTTPS (strongly recommended in production)
SESSION_SECURE=true
SESSION_HTTPONLY=true

# ── Mail ──────────────────────────────────────────────────────────────────────
MAIL_DRIVER=smtp
MAIL_HOST=smtp.your-provider.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME="${APP_NAME}"
